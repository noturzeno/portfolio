---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { getExperienceYears } from '../data/experience';

const yearsExp = getExperienceYears();
---

<Layout
	title="HOME // ZENO_TERMINAL"
	imagePreloads={[{ href: '/images/zeno.jpg', type: 'image/jpeg', fetchpriority: 'high' }]}
>
	<!-- TopAppBar -->
	<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface-container-lowest border-b border-outline/15 zeno-header-shadow">
		<a href="/" class="flex items-center gap-3">
			<span class="material-symbols-outlined text-secondary">terminal</span>
			<span class="text-xl font-black text-secondary tracking-[-0.04em] font-headline uppercase">Zeno Terminal</span>
		</a>
		<div class="hidden md:flex items-center gap-6">
			<nav class="flex gap-6">
				<a class="text-primary font-semibold font-label text-xs tracking-widest uppercase transition-all" href="/">Home</a>
				<a class="text-on-surface-variant hover:text-primary font-label text-xs tracking-widest uppercase transition-all" href="/projects">Projects</a>
				<a class="text-on-surface-variant hover:text-primary font-label text-xs tracking-widest uppercase transition-all" href="/about">About</a>
				<a class="text-on-surface-variant hover:text-primary font-label text-xs tracking-widest uppercase transition-all" href="/contact">Contact</a>
			</nav>
			<ThemeToggle />
		</div>
		<div class="md:hidden flex items-center gap-3 flex-wrap justify-end">
			<a class="font-label text-[10px] tracking-widest uppercase text-on-surface-variant hover:text-primary" href="/projects">Projects</a>
			<a class="font-label text-[10px] tracking-widest uppercase text-on-surface-variant hover:text-primary" href="/about">About</a>
			<a class="font-label text-[10px] tracking-widest uppercase text-on-surface-variant hover:text-primary" href="/contact">Contact</a>
			<ThemeToggle />
			<span class="material-symbols-outlined text-secondary" aria-hidden="true">menu</span>
		</div>
	</header>

	<main class="pt-16">
		<!-- Hero Section -->
		<section class="relative min-h-[795px] flex flex-col justify-center px-6 md:px-12 lg:px-24 overflow-hidden">
			<!-- Background Grid -->
			<div class="absolute inset-0 z-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(#FFD700 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
				<!-- Text Content -->
				<div class="lg:col-span-7 space-y-8">
					<div class="inline-flex items-center gap-2 px-3 py-1 border border-primary-fixed-dim/30 bg-surface-container-low">
						<span class="w-2 h-2 bg-primary-container rounded-full animate-pulse"></span>
						<span class="font-label text-[10px] uppercase tracking-[0.2em] text-primary-fixed-dim">System Status: Operational</span>
					</div>
					<h1 class="font-headline text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter leading-[0.9] text-on-surface">
						Architecting <br />
						<span class="text-secondary text-glow">High-Performance</span> <br />
						Digital Ecosystems.
					</h1>
					<p class="max-w-xl text-on-surface-variant font-body text-lg leading-relaxed">
						Full-stack Laravel engineer with {yearsExp}+ years shipping enterprise e-commerce, portals, and payment-adjacent systems — from analysis and architecture to deployment and team leadership. <span class="text-on-surface font-medium">Freelance and contract engagements</span> are welcome when the stack and scope are a strong fit.
					</p>
					<div class="flex flex-wrap gap-4 pt-4">
						<a
							href="/contact"
							class="inline-flex items-center px-8 py-4 bg-primary-container text-on-primary font-label font-bold text-sm tracking-widest rounded-none hover:shadow-[0_0_20px_rgba(255,215,0,0.4)] transition-all active:scale-95 group no-underline"
						>
							INIT_PROJECT()
							<span class="inline-block transition-transform group-hover:translate-x-1">_</span>
						</a>
						<a
							href="#stack"
							class="inline-flex items-center justify-center px-8 py-4 border border-outline/20 text-primary font-label text-sm tracking-widest rounded-none hover:bg-black/[0.04] transition-all active:scale-95 no-underline"
						>
							VIEW_STACK
						</a>
						<a
							href="/documents/Zeno-Resume.pdf"
							download="Zeno-Resume.pdf"
							class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-outline/20 text-primary font-label text-sm tracking-widest rounded-none hover:bg-black/[0.04] transition-all active:scale-95 no-underline"
						>
							<span class="material-symbols-outlined text-lg" aria-hidden="true">download</span>
							DOWNLOAD_CV
						</a>
					</div>
				</div>

				<!-- Technical Portrait Frame -->
				<div class="lg:col-span-5 relative group">
					<div class="absolute -inset-4 bg-primary-container/5 blur-3xl rounded-full"></div>
					<div class="relative aspect-[4/5] bg-surface-container-high border border-outline/10 p-4">
						<!-- Corner Ornaments -->
						<div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-primary-container"></div>
						<div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-primary-container"></div>
						<div class="w-full h-full relative overflow-hidden bg-surface-dim">
							<img
								alt="Zwel Linn Htet Ag"
								class="w-full h-full object-cover"
								src="/images/zeno.jpg"
								width={1024}
								height={1024}
								sizes="(max-width: 1024px) 100vw, 40vw"
								loading="eager"
								decoding="async"
								fetchpriority="high"
							/>
							<!-- UI Overlay -->
							<div class="absolute inset-0 bg-gradient-to-t from-surface-dim via-transparent to-transparent"></div>
							<div class="absolute bottom-4 left-4 right-4 flex justify-between items-end font-label text-[10px] text-white drop-shadow-[0_1px_2px_rgba(0,0,0,0.92)]">
								<div class="space-y-1">
									<p>USER: Z.L.H.A</p>
									<p>LOC: 13.7563° N, 100.5018° E</p>
								</div>
								<div class="text-right">
									<p>EXP: {yearsExp}+ YRS</p>
									<p>STATUS: SENIOR_DEV</p>
								</div>
							</div>
						</div>
					</div>
					<!-- Floating Data Tag -->
					<div class="absolute -top-6 -right-6 bg-surface-container-lowest border border-primary-container/20 p-4 font-label text-[10px] tracking-tighter text-on-surface-variant hidden md:block">
						<div class="flex items-center gap-2 mb-2">
							<span class="material-symbols-outlined text-[14px] text-secondary">memory</span>
							<span>CORE_OS: STABLE</span>
						</div>
						<div class="w-24 h-1 bg-surface-container-high overflow-hidden">
							<div class="w-2/3 h-full bg-primary-container"></div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Featured Work Section -->
		<section class="py-24 px-6 md:px-12 lg:px-24">
			<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
				<div class="space-y-2">
					<span class="font-label text-secondary text-xs tracking-[0.3em] uppercase">Repository / Projects</span>
					<h2 class="font-headline text-4xl md:text-5xl font-bold text-on-surface tracking-tighter uppercase">Selected Works</h2>
				</div>
				<div class="text-right hidden md:block">
					<span class="font-label text-[10px] text-outline uppercase tracking-widest">Featured: 03 · <a class="text-secondary hover:underline" href="/projects">View all</a></span>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-outline/10">
				<!-- Methodist Centre -->
				<a href="/projects/methodist-centre" class="group relative overflow-hidden bg-surface-container-low border-r border-outline/10 p-8 min-h-[450px] flex flex-col justify-between hover:bg-surface-container-high transition-colors duration-500 text-inherit no-underline">
					<div class="space-y-4">
						<div class="flex justify-between items-start">
							<span class="font-label text-secondary text-xs">01 // INSTITUTIONAL</span>
							<span class="material-symbols-outlined text-outline group-hover:text-secondary transition-colors">north_east</span>
						</div>
						<h3 class="font-headline text-3xl font-bold uppercase tracking-tight group-hover:text-secondary transition-colors">Methodist Centre</h3>
						<p class="text-on-surface-variant text-sm font-body leading-relaxed max-w-xs">
							Institutional web platform — programmes, content, and community-facing experiences.
						</p>
					</div>
					<div class="relative mt-8">
						<div class="aspect-video bg-surface-dim overflow-hidden border border-outline/5">
							<img
								alt="Methodist Centre"
								class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700"
								src="/images/projects/methodist-centre-banner.png"
								width={1280}
								height={720}
								sizes="(max-width: 768px) 100vw, 33vw"
								loading="lazy"
								decoding="async"
								fetchpriority="low"
							/>
						</div>
					</div>
				</a>

				<!-- Wahkee E-Commerce -->
				<a href="/projects/wahkee-ecommerce" class="group relative overflow-hidden bg-surface-container-low border-r border-outline/10 p-8 min-h-[450px] flex flex-col justify-between hover:bg-surface-container-high transition-colors duration-500 text-inherit no-underline">
					<div class="space-y-4">
						<div class="flex justify-between items-start">
							<span class="font-label text-secondary text-xs">02 // E-COMMERCE</span>
							<span class="material-symbols-outlined text-outline group-hover:text-secondary transition-colors">north_east</span>
						</div>
						<h3 class="font-headline text-3xl font-bold uppercase tracking-tight group-hover:text-secondary transition-colors">Wah Kee Pet Shop</h3>
						<p class="text-on-surface-variant text-sm font-body leading-relaxed max-w-xs">
							華記號 wkpet.com.hk — bilingual pet megastore, WAH KEE REWARDS, promos, and checkout — Laravel-led delivery.
						</p>
					</div>
					<div class="relative mt-8">
						<div class="aspect-video bg-surface-dim overflow-hidden border border-outline/5">
							<img
								alt="Wahkee E-Commerce"
								class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700"
								src="/images/projects/wahkee-banner.png"
								width={1280}
								height={720}
								sizes="(max-width: 768px) 100vw, 33vw"
								loading="lazy"
								decoding="async"
								fetchpriority="low"
							/>
						</div>
					</div>
				</a>

				<!-- HKU Alumni Giving -->
				<a href="/projects/hku-alumni-giving" class="group relative overflow-hidden bg-surface-container-low p-8 min-h-[450px] flex flex-col justify-between hover:bg-surface-container-high transition-colors duration-500 text-inherit no-underline">
					<div class="space-y-4">
						<div class="flex justify-between items-start">
							<span class="font-label text-secondary text-xs">03 // PAYMENTS</span>
							<span class="material-symbols-outlined text-outline group-hover:text-secondary transition-colors">north_east</span>
						</div>
						<h3 class="font-headline text-3xl font-bold uppercase tracking-tight group-hover:text-secondary transition-colors">HKU Alumni Giving</h3>
						<p class="text-on-surface-variant text-sm font-body leading-relaxed max-w-xs">
							alumnigiving.hku.hk — donation funnel, designated fund routing, and payment integration for HKU alumni & friends giving.
						</p>
					</div>
					<div class="relative mt-8">
						<div class="aspect-video bg-surface-dim overflow-hidden border border-outline/5">
							<img
								alt="HKU Alumni Giving donate experience"
								class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700"
								src="/images/projects/hku-mass-giving-banner.jpg"
								width={1280}
								height={720}
								sizes="(max-width: 768px) 100vw, 33vw"
								loading="lazy"
								decoding="async"
								fetchpriority="low"
							/>
						</div>
					</div>
				</a>
			</div>
		</section>

		<!-- Technical Specs Marquee -->
		<section id="stack" class="scroll-mt-24 py-12 border-y border-outline/5 overflow-hidden whitespace-nowrap bg-surface-container-lowest">
			<div class="flex gap-24 items-center animate-marquee font-label text-[10px] tracking-[0.5em] text-outline/75 uppercase">
				<span>Laravel</span>
				<span class="text-secondary">●</span>
				<span>PHP</span>
				<span class="text-secondary">●</span>
				<span>Vue.js</span>
				<span class="text-secondary">●</span>
				<span>Inertia.js</span>
				<span class="text-secondary">●</span>
				<span>TypeScript</span>
				<span class="text-secondary">●</span>
				<span>Node.js</span>
				<span class="text-secondary">●</span>
				<span>WordPress</span>
				<span class="text-secondary">●</span>
				<span>MySQL</span>
				<span class="text-secondary">●</span>
				<span>Yii</span>
				<span class="text-secondary">●</span>
				<span>Git</span>
				<span class="text-secondary">●</span>
				<span>Figma</span>
				<span class="text-secondary">●</span>
				<span>Scrum / Agile</span>
				<span class="text-secondary">●</span>
				<span>Laravel</span>
				<span class="text-secondary">●</span>
				<span>PHP</span>
				<span class="text-secondary">●</span>
				<span>Vue.js</span>
				<span class="text-secondary">●</span>
				<span>Inertia.js</span>
				<span class="text-secondary">●</span>
				<span>TypeScript</span>
				<span class="text-secondary">●</span>
				<span>Node.js</span>
				<span class="text-secondary">●</span>
				<span>WordPress</span>
				<span class="text-secondary">●</span>
				<span>MySQL</span>
				<span class="text-secondary">●</span>
				<span>Yii</span>
				<span class="text-secondary">●</span>
				<span>Git</span>
				<span class="text-secondary">●</span>
				<span>Figma</span>
				<span class="text-secondary">●</span>
				<span>Scrum / Agile</span>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="w-full py-12 px-6 flex flex-col md:flex-row justify-between items-center gap-6 border-t border-outline/10 bg-surface-container-lowest">
		<div class="flex flex-col md:flex-row items-center gap-8">
			<p class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant">
				© {new Date().getFullYear()} THE ZENO TERMINAL. ALL RIGHTS RESERVED.
			</p>
		</div>
		<div class="flex gap-8 flex-wrap justify-center">
			<a class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant hover:text-primary transition-colors" href="#">GITHUB</a>
			<a class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant hover:text-primary transition-colors" href="https://www.linkedin.com/in/zwelinnhtetag" target="_blank" rel="noopener noreferrer">LINKEDIN</a>
			<a class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant hover:text-primary transition-colors" href="/projects">PROJECTS</a>
			<a class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant hover:text-primary transition-colors" href="/about">ABOUT</a>
			<a class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant hover:text-primary transition-colors" href="/contact">CONTACT</a>
			<div class="flex items-center gap-2">
				<span class="w-1.5 h-1.5 bg-green-600 rounded-full"></span>
				<span class="font-label text-[10px] tracking-[0.1em] uppercase text-secondary">SYSTEM_STATUS: OPTIMAL</span>
			</div>
		</div>
	</footer>
</Layout>
