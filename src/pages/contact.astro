---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---

<Layout title="CONTACT // ZENO_TERMINAL">
	<!-- TopAppBar -->
	<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface-container-lowest border-b border-outline/15 zeno-header-shadow">
		<a href="/" class="flex items-center gap-3">
			<span class="material-symbols-outlined text-secondary">terminal</span>
			<span class="text-xl font-black text-secondary tracking-[-0.04em] font-headline uppercase">ZENO_TERMINAL</span>
		</a>
		<div class="hidden md:flex items-center gap-6">
			<nav class="flex items-center gap-8 font-label text-[10px] tracking-widest text-on-surface-variant">
				<a class="hover:text-primary transition-all" href="/">HOME</a>
				<a class="hover:text-primary transition-all" href="/projects">PROJECTS</a>
				<a class="hover:text-primary transition-all" href="/about">ABOUT</a>
				<a class="text-primary font-semibold" href="/contact">CONTACT</a>
			</nav>
			<ThemeToggle />
		</div>
		<div class="flex items-center gap-2 md:hidden">
			<ThemeToggle />
			<button type="button" class="text-secondary p-2 hover:bg-surface-container-high transition-all bg-transparent border-0 cursor-pointer" aria-label="Menu">
				<span class="material-symbols-outlined">menu</span>
			</button>
		</div>
	</header>

	<main class="pt-32 pb-20 px-6 max-w-7xl mx-auto min-h-screen">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
			<!-- Left Column -->
			<div class="lg:col-span-5 flex flex-col justify-between gap-16">
				<div>
					<div class="inline-flex items-center gap-2 px-3 py-1 border border-primary-container/20 bg-primary-container/5 rounded-none mb-8">
						<span class="w-1.5 h-1.5 bg-primary-container animate-pulse"></span>
						<span class="font-label text-[10px] tracking-widest text-secondary uppercase">CONNECTION_REQUEST_PENDING</span>
					</div>
					<h1 class="font-headline text-6xl md:text-8xl font-bold tracking-tighter leading-none text-on-surface mb-8">
						ESTABLISH<br />
						<span class="text-secondary">CONNECTION</span>
					</h1>
					<p class="font-body text-lg text-on-surface-variant max-w-md mb-12 leading-relaxed">
						Initiate direct uplink for strategic partnerships, architectural consultation, or system inquiries. All transmissions are routed through secured protocols.
					</p>
				</div>
				<div class="space-y-6">
					<h3 class="font-label text-xs tracking-[0.2em] text-outline uppercase">AUTHENTICATED_CHANNELS</h3>
					<div class="flex flex-col gap-4">
						<a class="group flex items-center justify-between p-4 bg-surface-container-high border-l-2 border-transparent hover:border-primary-container hover:bg-surface-container-highest transition-all duration-300" href="#" target="_blank" rel="noopener noreferrer">
							<div class="flex items-center gap-4">
								<span class="material-symbols-outlined text-outline group-hover:text-secondary transition-colors">terminal</span>
								<span class="font-label text-sm tracking-widest">GITHUB</span>
							</div>
							<span class="material-symbols-outlined text-outline group-hover:translate-x-1 transition-transform">north_east</span>
						</a>
						<a class="group flex items-center justify-between p-4 bg-surface-container-high border-l-2 border-transparent hover:border-primary-container hover:bg-surface-container-highest transition-all duration-300" href="https://www.linkedin.com/in/zwelinnhtetag" target="_blank" rel="noopener noreferrer">
							<div class="flex items-center gap-4">
								<span class="material-symbols-outlined text-outline group-hover:text-secondary transition-colors">link</span>
								<span class="font-label text-sm tracking-widest">LINKEDIN</span>
							</div>
							<span class="material-symbols-outlined text-outline group-hover:translate-x-1 transition-transform">north_east</span>
						</a>
						<a class="group flex items-center justify-between p-4 bg-surface-container-high border-l-2 border-transparent hover:border-primary-container hover:bg-surface-container-highest transition-all duration-300" href="mailto:zwelinnhtetag@gmail.com">
							<div class="flex items-center gap-4">
								<span class="material-symbols-outlined text-outline group-hover:text-secondary transition-colors">alternate_email</span>
								<span class="font-label text-sm tracking-widest">EMAIL</span>
							</div>
							<span class="material-symbols-outlined text-outline group-hover:translate-x-1 transition-transform">north_east</span>
						</a>
						<a class="group flex items-center justify-between p-4 bg-surface-container-high border-l-2 border-transparent hover:border-primary-container hover:bg-surface-container-highest transition-all duration-300" href="tel:+66984382245">
							<div class="flex items-center gap-4">
								<span class="material-symbols-outlined text-outline group-hover:text-secondary transition-colors">call</span>
								<span class="font-label text-sm tracking-widest">PHONE · TH</span>
							</div>
							<span class="material-symbols-outlined text-outline group-hover:translate-x-1 transition-transform">north_east</span>
						</a>
					</div>
				</div>
			</div>

			<!-- Right Column: Form -->
			<div class="lg:col-span-7">
				<div class="relative">
					<div class="absolute -inset-4 bg-primary-container/5 blur-3xl rounded-none -z-10"></div>
					<div class="bg-surface-container-low border border-outline/10 shadow-2xl overflow-hidden">
						<div class="bg-surface-container-lowest px-4 py-3 border-b border-outline/10 flex items-center justify-between">
							<div class="flex gap-2">
								<div class="w-2.5 h-2.5 rounded-full bg-primary-fixed-dim opacity-40"></div>
								<div class="w-2.5 h-2.5 rounded-full bg-primary-fixed-dim opacity-60"></div>
								<div class="w-2.5 h-2.5 rounded-full bg-primary-fixed-dim opacity-80"></div>
							</div>
							<span class="font-label text-[10px] text-on-surface-variant tracking-widest">SECURE_INTERFACE_V4.0</span>
						</div>
						<form id="contact-form" class="p-8 md:p-12 space-y-12" method="post" action="#">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
								<div class="relative">
									<label class="block font-label text-[10px] tracking-widest text-outline mb-2 uppercase" for="contact-name">SUBJECT_IDENTITY</label>
									<input
										id="contact-name"
										name="name"
										class="w-full bg-transparent border-b border-outline-variant focus:border-primary-container focus:ring-0 text-on-surface py-2 font-label text-sm transition-colors placeholder:text-outline/55"
										placeholder="ENTITY NAME"
										type="text"
										autocomplete="name"
									/>
								</div>
								<div class="relative">
									<label class="block font-label text-[10px] tracking-widest text-outline mb-2 uppercase" for="contact-email">PROTOCOL_ADDRESS</label>
									<input
										id="contact-email"
										name="email"
										class="w-full bg-transparent border-b border-outline-variant focus:border-primary-container focus:ring-0 text-on-surface py-2 font-label text-sm transition-colors placeholder:text-outline/55"
										placeholder="EMAIL_URI"
										type="email"
										autocomplete="email"
									/>
								</div>
							</div>
							<div class="relative">
								<label class="block font-label text-[10px] tracking-widest text-outline mb-2 uppercase" for="contact-message">TRANSMISSION_PAYLOAD</label>
								<textarea
									id="contact-message"
									name="message"
									class="w-full bg-transparent border-b border-outline-variant focus:border-primary-container focus:ring-0 text-on-surface py-2 font-label text-sm transition-colors resize-none placeholder:text-outline/55"
									placeholder="DEFINE_OBJECTIVES_HERE..."
									rows="6"
								></textarea>
							</div>
							<div class="flex flex-col md:flex-row items-center justify-between gap-8 pt-6">
								<div class="flex items-center gap-4 text-on-surface-variant font-label text-[10px]">
									<span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">lock</span>
									<span>ENCRYPTION: AES-256-GCM</span>
								</div>
								<button class="group relative w-full md:w-auto px-10 py-4 bg-primary-container text-on-primary font-label font-bold tracking-widest text-sm overflow-hidden transition-all active:scale-95 gilded-glow" type="submit">
									<span class="relative z-10">EXECUTE_SEND &gt;</span>
									<div class="absolute inset-0 bg-on-primary/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
								</button>
							</div>
						</form>
					</div>
					<div class="mt-8 flex justify-end">
						<div class="font-label text-[10px] text-on-surface-variant text-right max-w-xs leading-loose opacity-75">
							[TRANSMISSION_PROTOCOL] SOURCE_IP: REDACTED<br />
							[STATUS] READY_FOR_UPLINK<br />
							[TIMESTAMP] {new Date().getFullYear()}.{new Date().getMonth() + 1}.{new Date().getDate()}_04:18:09_UTC
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>

	<footer class="w-full py-8 px-6 flex flex-col md:flex-row justify-between items-center gap-4 bg-surface-container-lowest border-t border-outline/10">
		<div class="flex flex-col sm:flex-row items-center gap-4 font-label text-[10px] tracking-[0.1em] uppercase order-2 md:order-1">
			<div class="flex items-center gap-2 text-secondary">
				<span class="w-1.5 h-1.5 rounded-full bg-primary-container animate-pulse"></span>
				SYSTEM_STATUS: OPTIMAL
			</div>
			<div class="h-4 w-px bg-outline/25 hidden sm:block"></div>
			<span class="text-on-surface-variant">UPLINK_STRENGTH: 99.9%</span>
		</div>
		<div class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant order-1 md:order-2 text-center">
			© {new Date().getFullYear()} THE ZENO TERMINAL. ALL RIGHTS RESERVED.
		</div>
		<div class="flex gap-6 font-label text-[10px] tracking-[0.1em] uppercase order-3">
			<a class="text-on-surface-variant hover:text-primary transition-opacity" href="#">GITHUB</a>
			<a class="text-on-surface-variant hover:text-primary transition-opacity" href="https://www.linkedin.com/in/zwelinnhtetag" target="_blank" rel="noopener noreferrer">LINKEDIN</a>
		</div>
	</footer>

	<div class="fixed right-4 top-1/2 -translate-y-1/2 hidden xl:flex flex-col gap-8 items-center pointer-events-none opacity-40">
		<div class="w-px h-32 bg-primary-container"></div>
		<span class="font-label text-[10px] tracking-[0.5em] rotate-90 text-secondary whitespace-nowrap">INTERFACE_LAYER_01</span>
		<div class="w-px h-32 bg-primary-container"></div>
	</div>

	<script is:inline>
		document.getElementById('contact-form')?.addEventListener('submit', function (e) {
			e.preventDefault();
		});
	</script>
</Layout>
