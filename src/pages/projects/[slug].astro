---
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { projects, getProjectBySlug, type ProjectDetail } from '../../data/projects';
import { getExperienceYears } from '../../data/experience';
import { mimeForPublicImage } from '../../utils/imageMime';

export const prerender = true;

const yearsExp = getExperienceYears();

export function getStaticPaths() {
	return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug!)!;

const codeInner = project.codeSnippetLines.join('\n');

const closingCtaExternal =
	project.closingSingleCta != null && /^https?:\/\//i.test(project.closingSingleCta.href);

function pageTitle(p: ProjectDetail) {
	return `${p.title.replace(/_/g, ' ')} // CASE STUDY`;
}

const caseStudyImagePreloads =
	project.status !== 'INTERNAL'
		? [
				{
					href: project.schematicImage,
					type: mimeForPublicImage(project.schematicImage),
					fetchpriority: 'high' as const,
				},
			]
		: [];
---

<Layout title={pageTitle(project)} imagePreloads={caseStudyImagePreloads}>
	<!-- TopAppBar -->
	<header
		class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface-container-lowest border-b border-outline/15 zeno-header-shadow"
	>
		<a href="/" class="flex items-center gap-3">
			<span class="material-symbols-outlined text-secondary">terminal</span>
			<span class="font-headline font-black text-xl text-secondary tracking-[-0.04em] uppercase">ZENO_TERMINAL</span>
		</a>
		<div class="hidden md:flex items-center gap-6">
			<nav class="flex gap-6 font-label text-[10px] tracking-widest uppercase">
				<a class="text-on-surface-variant hover:text-primary transition-all" href="/">Home</a>
				<a class="text-primary font-semibold transition-all" href="/projects">Projects</a>
				<a class="text-on-surface-variant hover:text-primary transition-all" href="/about">About</a>
				<a class="text-on-surface-variant hover:text-primary transition-all" href="/contact">Contact</a>
			</nav>
			<ThemeToggle />
			<span class="material-symbols-outlined text-secondary cursor-pointer" aria-hidden="true">menu</span>
		</div>
		<div class="flex items-center gap-2 md:hidden">
			<ThemeToggle />
			<span class="material-symbols-outlined text-secondary cursor-pointer" aria-hidden="true">menu</span>
		</div>
	</header>

	<!-- Side Navigation (lg+) -->
	<aside class="hidden lg:flex fixed inset-y-0 left-0 z-[60] w-80 flex-col bg-surface-container-lowest border-r border-outline/10 pt-20">
		<div class="px-6 py-8 border-b border-outline/10">
			<div class="flex items-center gap-4 mb-4">
				<div class="w-12 h-12 bg-surface-container-high border border-primary-container/20 flex items-center justify-center">
					<span class="material-symbols-outlined text-secondary">person</span>
				</div>
				<div>
					<h3 class="font-label text-xs uppercase tracking-widest text-secondary">Zwel Linn Htet Ag</h3>
					<p class="font-label text-[10px] text-outline">Senior Developer</p>
				</div>
			</div>
			<div class="bg-surface-container-lowest px-3 py-1 inline-block border border-primary-container/10">
				<span class="font-label text-[10px] text-secondary">{yearsExp}+ YRS</span>
			</div>
		</div>
		<nav class="flex-1 py-6 flex flex-col font-label text-xs uppercase tracking-widest">
			<a class="text-on-surface-variant px-8 py-4 hover:bg-surface-container-high hover:text-primary transition-colors flex items-center gap-4" href="/">
				<span class="material-symbols-outlined text-lg">home</span> Home
			</a>
			<a class="bg-primary-container text-on-primary font-bold px-8 py-4 flex items-center gap-4" href="/projects">
				<span class="material-symbols-outlined text-lg">code</span> Projects
			</a>
			<a class="text-on-surface-variant px-8 py-4 hover:bg-surface-container-high hover:text-primary transition-colors flex items-center gap-4" href="/about">
				<span class="material-symbols-outlined text-lg">person</span> About
			</a>
			<a class="text-on-surface-variant px-8 py-4 hover:bg-surface-container-high hover:text-primary transition-colors flex items-center gap-4" href="/contact">
				<span class="material-symbols-outlined text-lg">mail</span> Contact
			</a>
		</nav>
	</aside>

	<main class="lg:pl-80 pt-16 min-h-screen pb-28 lg:pb-0">
		<section class="relative px-6 py-20 md:py-32 overflow-hidden">
			<div class="absolute top-0 right-0 w-1/2 h-full opacity-20 pointer-events-none">
				<div class="w-full h-full bg-[radial-gradient(circle_at_50%_50%,_#ffd70033_0%,_transparent_70%)]"></div>
			</div>
			<div class="max-w-5xl relative z-10">
				<div class="flex items-center gap-4 mb-6 flex-wrap">
					<span class="font-label text-xs tracking-[0.2em] text-secondary uppercase bg-surface-container-high px-3 py-1 border border-outline-variant/30">
						Case study #{project.caseStudyId}
					</span>
					<div class="h-[1px] w-20 bg-outline-variant/30"></div>
				</div>
				<h2 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter uppercase mb-8 leading-none">
					{project.heroTitleLine1}<br />
					<span class="text-sheen">{project.heroTitleSheen}</span>
				</h2>
				<p class="font-body text-xl text-on-surface-variant max-w-2xl mb-12 leading-relaxed">
					{project.heroDesc}
				</p>
				<div class="flex flex-wrap gap-4">
					{
						project.liveUrl ? (
							<a
								href={project.liveUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="bg-primary-container text-on-primary font-label text-sm font-bold uppercase tracking-widest px-8 py-4 flex items-center gap-2 hover:glow-primary transition-all"
							>
								LIVE_SITE <span class="material-symbols-outlined text-lg">arrow_outward</span>
							</a>
						) : null
					}
					<a
						href="https://www.linkedin.com/in/zwelinnhtetag/"
						target="_blank"
						rel="noopener noreferrer"
						class="border border-outline/20 text-secondary font-label text-sm uppercase tracking-widest px-8 py-4 flex items-center gap-2 hover:bg-black/[0.04] transition-all"
					>
						LINKEDIN <span class="material-symbols-outlined text-lg">link</span>
					</a>
				</div>
			</div>
		</section>

		<section class="px-6 pb-24 max-w-7xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
				<div class="md:col-span-8 bg-surface-container-low p-8 border-l-2 border-primary-container/20 relative overflow-hidden group">
					<div class="absolute -right-10 -top-10 text-9xl font-black text-on-surface/[0.06] select-none pointer-events-none group-hover:text-secondary/10 transition-colors">
						{project.number}
					</div>
					<h3 class="font-label text-xs text-secondary tracking-widest uppercase mb-6 flex items-center gap-2">
						<span class="w-2 h-2 bg-primary-container"></span> THE CHALLENGE
					</h3>
					<p class="text-on-surface-variant leading-relaxed text-lg">
						{project.challenge}
					</p>
				</div>

				<div class="md:col-span-4 bg-surface-container-high p-8 flex flex-col justify-between border-t-2 border-secondary/20">
					<div>
						<h3 class="font-label text-xs text-secondary tracking-widest uppercase mb-6">PROJECT STATUS</h3>
						<div class="flex items-center gap-3 mb-4">
							<span class="relative flex h-3 w-3">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75"></span>
								<span class="relative inline-flex rounded-full h-3 w-3 bg-secondary"></span>
							</span>
							<span class="font-label text-sm uppercase">DEPLOYED: {project.deployedVersion}</span>
						</div>
					</div>
					<div class="space-y-4">
						<div class="flex justify-between items-center border-b border-outline/10 pb-2">
							<span class="text-[10px] text-outline uppercase font-label">Uptime</span>
							<span class="text-xs font-label">{project.uptime}</span>
						</div>
						<div class="flex justify-between items-center border-b border-outline/10 pb-2">
							<span class="text-[10px] text-outline uppercase font-label">Latency</span>
							<span class="text-xs font-label">{project.latency}</span>
						</div>
					</div>
				</div>

				<div class="md:col-span-4 bg-surface-container-high p-8 border-r-2 border-primary-container/20">
					<h3 class="font-label text-xs text-secondary tracking-widest uppercase mb-8">TECHNICAL STACK</h3>
					<ul class="space-y-6 font-label text-sm">
						{
							project.stack.map((item) => (
								<li class="flex items-center justify-between group">
									<span class="text-on-surface-variant group-hover:text-primary transition-colors">{item}</span>
									<span class="material-symbols-outlined text-xs text-outline group-hover:text-primary">check_circle</span>
								</li>
							))
						}
					</ul>
				</div>

				<div class="md:col-span-8 bg-surface-container-low p-8 border-b-2 border-outline-variant/30">
					<h3 class="font-label text-xs text-secondary tracking-widest uppercase mb-6 flex items-center gap-2">
						<span class="w-2 h-2 bg-primary-container"></span> THE SOLUTION
					</h3>
					<div class="grid md:grid-cols-2 gap-8">
						<p class="text-on-surface-variant leading-relaxed">{project.solution1}</p>
						<p class="text-on-surface-variant leading-relaxed">{project.solution2}</p>
					</div>
				</div>

				<div class="md:col-span-12 bg-surface-container-lowest p-0 border border-outline/10">
					<div class="bg-surface-container-highest px-4 py-2 flex items-center justify-between">
						<div class="flex gap-2">
							<div class="w-2 h-2 rounded-full bg-primary-fixed-dim/40"></div>
							<div class="w-2 h-2 rounded-full bg-primary-fixed-dim/40"></div>
							<div class="w-2 h-2 rounded-full bg-primary-fixed-dim/40"></div>
						</div>
						<span class="font-label text-[10px] uppercase text-outline">CODE_SNIPPET: {project.codeFileLabel}</span>
					</div>
					<div class="px-8 pt-6 pb-2 border-b border-outline/10 bg-surface-container-low/30">
						<h3 class="font-label text-[10px] uppercase tracking-[0.2em] text-secondary mb-3 flex items-center gap-2">
							<span class="w-1.5 h-1.5 rounded-full bg-primary-container"></span>
							What this code is doing
						</h3>
						<p class="font-body text-sm md:text-base text-on-surface-variant leading-relaxed max-w-4xl">
							{project.codeSnippetExplanation}
						</p>
					</div>
					<div class="p-8 overflow-x-auto font-label text-sm leading-relaxed text-on-surface-variant">
						<pre><code set:html={codeInner}></code></pre>
					</div>
				</div>

				<div class="md:col-span-12 flex flex-col md:flex-row gap-12 items-center py-12 border-y border-outline/10">
					<div class="md:w-1/3">
						<h3 class="font-headline text-3xl font-bold uppercase tracking-tight mb-4">
							ARCHITECTURE<br /><span class="text-secondary">NOTE</span>
						</h3>
						<p class="text-on-surface-variant text-sm font-label uppercase leading-relaxed tracking-widest">
							"{project.architectureQuote}"
						</p>
					</div>
					<div class="md:w-2/3">
						{
							project.status === 'INTERNAL' ? (
								<div
									class="w-full min-h-[240px] md:min-h-[320px] flex items-center justify-center bg-surface-container-low border border-outline/15"
									aria-hidden="true"
								>
									<span class="material-symbols-outlined text-[clamp(4rem,15vw,8rem)] text-secondary/50 select-none">
										{project.icon}
									</span>
								</div>
							) : (
								<img
									alt={`${project.title.replace(/_/g, ' ')} — banner or key visual from the deployed site`}
									class="w-full transition-all duration-700"
									src={project.schematicImage}
									width={1280}
									height={720}
									sizes="(max-width: 768px) 100vw, 66vw"
									loading="eager"
									decoding="async"
									fetchpriority="high"
								/>
							)
						}
					</div>
				</div>
			</div>
		</section>

		<section class="px-6 py-24 bg-surface-container-low border-t border-outline/10">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="font-headline text-4xl md:text-5xl font-bold uppercase tracking-tighter mb-8">
					{project.closingTitle ?? 'Ready to see it in action?'}
				</h2>
				<p class="font-body text-on-surface-variant mb-12 max-w-2xl mx-auto">
					{
						project.closingDesc ??
							'Deploy the orchestration layer to your local dev cluster in under 3 minutes. Comprehensive documentation and repository access provided below.'
					}
				</p>
				{
					project.closingSingleCta ? (
						<div class="flex flex-col sm:flex-row justify-center gap-6">
							<a
								href={project.closingSingleCta.href}
								target={closingCtaExternal ? '_blank' : undefined}
								rel={closingCtaExternal ? 'noopener noreferrer' : undefined}
								class="bg-primary-container text-on-primary font-label text-xs font-bold uppercase tracking-[0.2em] px-10 py-5 hover:glow-primary transition-all inline-flex items-center justify-center gap-2"
							>
								{project.closingSingleCta.label}
								<span class="material-symbols-outlined text-lg">arrow_outward</span>
							</a>
							<a
								href="/projects"
								class="border border-outline/20 text-on-surface font-label text-xs font-bold uppercase tracking-[0.2em] px-10 py-5 hover:bg-black/[0.04] transition-all inline-flex items-center justify-center"
							>
								ALL_PROJECTS
							</a>
						</div>
					) : (
						<div class="flex flex-col sm:flex-row justify-center gap-6">
							<button type="button" class="bg-primary-container text-on-primary font-label text-xs font-bold uppercase tracking-[0.2em] px-10 py-5 hover:glow-primary transition-all">
								EXPLORE_DOCS
							</button>
							<button type="button" class="border border-outline/20 text-on-surface font-label text-xs font-bold uppercase tracking-[0.2em] px-10 py-5 hover:bg-black/[0.04] transition-all">
								REVIEW_REPO
							</button>
						</div>
					)
				}
			</div>
		</section>

		<footer class="w-full py-8 px-6 flex flex-col md:flex-row justify-between items-center gap-4 bg-surface-container-lowest border-t border-outline/10">
			<div class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant">
				© {new Date().getFullYear()} THE ZENO TERMINAL. ALL RIGHTS RESERVED.
			</div>
			<div class="flex gap-8 font-label text-[10px] tracking-[0.1em] uppercase flex-wrap justify-center">
				<a class="text-on-surface-variant hover:text-primary transition-all" href="https://github.com/noturzeno" target="_blank" rel="noopener noreferrer">GITHUB</a>
				<a class="text-on-surface-variant hover:text-primary transition-all" href="https://www.linkedin.com/in/zwelinnhtetag/" target="_blank" rel="noopener noreferrer">LINKEDIN</a>
				<a class="text-on-surface-variant hover:text-primary transition-all" href="/projects">ALL_PROJECTS</a>
				<span class="text-secondary underline">SYSTEM_STATUS: OPTIMAL</span>
			</div>
		</footer>
	</main>

	<nav class="lg:hidden fixed bottom-0 w-full bg-surface-container-high border-t border-outline/15 px-6 py-4 z-50 flex justify-between items-center shadow-lg">
		<a class="flex flex-col items-center gap-1 text-on-surface-variant transition-all" href="/">
			<span class="material-symbols-outlined">home</span>
			<span class="font-label text-[8px] uppercase">Home</span>
		</a>
		<a class="flex flex-col items-center gap-1 text-primary font-semibold transition-all" href="/projects">
			<span class="material-symbols-outlined">code</span>
			<span class="font-label text-[8px] uppercase">Projects</span>
		</a>
		<a class="flex flex-col items-center gap-1 text-on-surface-variant transition-all" href="/about">
			<span class="material-symbols-outlined">person</span>
			<span class="font-label text-[8px] uppercase">About</span>
		</a>
		<a class="flex flex-col items-center gap-1 text-on-surface-variant transition-all" href="/contact">
			<span class="material-symbols-outlined">mail</span>
			<span class="font-label text-[8px] uppercase">Contact</span>
		</a>
	</nav>
</Layout>
