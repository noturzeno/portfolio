---
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { projects } from '../../data/projects';
import { getExperienceYears } from '../../data/experience';
import { mimeForPublicImage } from '../../utils/imageMime';

const yearsExp = getExperienceYears();
const byImpression = (a: (typeof projects)[number], b: (typeof projects)[number]) =>
	b.impressionWeight - a.impressionWeight;
const launchedProjects = projects.filter((p) => p.status !== 'INTERNAL').sort(byImpression);
const internalProjects = projects.filter((p) => p.status === 'INTERNAL').sort(byImpression);

const firstPublicThumb = launchedProjects[0]?.schematicImage;
const projectImagePreloads =
	firstPublicThumb != null
		? [
				{
					href: firstPublicThumb,
					type: mimeForPublicImage(firstPublicThumb),
					fetchpriority: 'high' as const,
				},
			]
		: [];
---

<Layout title="RECENT PROJECTS // ZENO_TERMINAL" imagePreloads={projectImagePreloads}>
	<!-- TopAppBar -->
	<header
		class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface-container-lowest border-b border-outline/15 zeno-header-shadow"
	>
		<a href="/" class="flex items-center gap-3">
			<span class="material-symbols-outlined text-secondary">terminal</span>
			<span class="font-headline font-bold tracking-tighter uppercase text-xl font-black text-secondary tracking-[-0.04em]">ZENO_TERMINAL</span>
		</a>
		<div class="flex items-center gap-2">
			<ThemeToggle />
			<button
				type="button"
				class="material-symbols-outlined text-secondary hover:bg-surface-container-high p-2 transition-all active:scale-95 duration-150 lg:hidden bg-transparent border-0 cursor-pointer"
				aria-label="Open menu"
				aria-controls="mobile-menu-projects"
				aria-expanded="false"
				data-mobile-menu-toggle
			>
				menu
			</button>
		</div>
		<nav
			id="mobile-menu-projects"
			class="lg:hidden hidden absolute top-16 left-0 right-0 bg-surface-container-lowest border-b border-outline/15 px-6 py-4"
			data-mobile-menu
		>
			<div class="flex flex-col gap-3 font-label text-xs tracking-widest uppercase">
				<a class="text-on-surface-variant hover:text-primary" href="/">Home</a>
				<a class="text-primary font-semibold" href="/projects">Projects</a>
				<a class="text-on-surface-variant hover:text-primary" href="/about">About</a>
				<a class="text-on-surface-variant hover:text-primary" href="/contact">Contact</a>
			</div>
		</nav>
	</header>

	<!-- Side Navigation -->
	<aside class="fixed inset-y-0 left-0 z-[60] hidden lg:flex flex-col h-full w-80 border-r border-outline/10 bg-surface-container-lowest">
		<div class="p-8 border-b border-outline/10">
			<div class="flex items-center gap-4">
				<div class="w-12 h-12 bg-surface-container-high flex items-center justify-center border border-primary-container/20">
					<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">person</span>
				</div>
				<div>
					<h3 class="font-label uppercase tracking-widest text-xs font-bold text-secondary">Zwel Linn Htet Ag</h3>
					<p class="text-[10px] text-outline font-label uppercase">Software Engineer</p>
					<span class="text-[9px] px-1 bg-primary-container/10 text-secondary border border-primary-container/20 mt-1 inline-block">{yearsExp}+ YRS</span>
				</div>
			</div>
		</div>
		<nav class="flex-1 py-6">
			<ul class="space-y-1">
				<li>
					<a class="flex items-center gap-4 text-on-surface-variant px-8 py-3 font-label uppercase tracking-widest text-xs hover:bg-surface-container-high hover:text-primary transition-colors duration-200" href="/">
						<span class="material-symbols-outlined text-sm">home</span> Home
					</a>
				</li>
				<li>
					<a class="flex items-center gap-4 bg-primary-container text-on-primary font-bold px-8 py-3 font-label uppercase tracking-widest text-xs transition-colors duration-200" href="/projects">
						<span class="material-symbols-outlined text-sm">code</span> Recent projects
					</a>
				</li>
				<li>
					<a class="flex items-center gap-4 text-on-surface-variant px-8 py-3 font-label uppercase tracking-widest text-xs hover:bg-surface-container-high hover:text-primary transition-colors duration-200" href="/about">
						<span class="material-symbols-outlined text-sm">person</span> About
					</a>
				</li>
				<li>
					<a class="flex items-center gap-4 text-on-surface-variant px-8 py-3 font-label uppercase tracking-widest text-xs hover:bg-surface-container-high hover:text-primary transition-colors duration-200" href="/contact">
						<span class="material-symbols-outlined text-sm">mail</span> Contact
					</a>
				</li>
			</ul>
		</nav>
	</aside>

	<main class="pt-24 pb-16 px-6 lg:ml-80">
		<div class="max-w-7xl mx-auto">
			<section class="mb-14">
				<div class="space-y-4">
					<span class="font-label text-xs tracking-[0.2em] text-secondary font-bold uppercase">RECENT_PROJECTS</span>
					<h1 class="font-headline text-6xl md:text-8xl font-bold tracking-[-0.06em] text-on-surface leading-none">
						Recent <span class="text-secondary">projects</span><span class="text-outline">_</span>
					</h1>
					<p class="max-w-2xl text-outline font-body text-lg leading-relaxed pt-4 border-l-2 border-primary-container/30 pl-6">
						Latest client and production work — live and staging — with full case studies. Internal builds and private codebases sit below in a horizontal strip; same depth, no public demo URL.
					</p>
				</div>
			</section>

			<section class="mb-6" aria-labelledby="launched-heading">
				<div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-8">
					<div class="space-y-2">
						<p class="font-label text-[10px] tracking-[0.35em] text-outline uppercase">INDEX · PUBLIC</p>
						<h2 id="launched-heading" class="font-headline text-3xl md:text-4xl font-bold tracking-tight text-on-surface">
							Recent <span class="text-secondary">projects</span>
						</h2>
						<p class="font-label text-[10px] tracking-[0.2em] text-outline uppercase max-w-md">
							Live &amp; staging — filter by stack or domain
						</p>
					</div>
					<div class="flex flex-wrap gap-2 font-label text-[10px] tracking-widest" id="project-filters">
						<button type="button" data-filter="all" class="filter-btn filter-btn--active px-4 py-2 uppercase">ALL_UNITS</button>
						<button type="button" data-filter="LARAVEL" class="filter-btn px-4 py-2 uppercase">LARAVEL</button>
						<button type="button" data-filter="VUE" class="filter-btn px-4 py-2 uppercase">VUE</button>
						<button type="button" data-filter="HEALTH" class="filter-btn px-4 py-2 uppercase">HEALTH</button>
						<button type="button" data-filter="ECOMMERCE" class="filter-btn px-4 py-2 uppercase">ECOMMERCE</button>
						<button type="button" data-filter="EDUCATION" class="filter-btn px-4 py-2 uppercase">EDUCATION</button>
						<button type="button" data-filter="CMS" class="filter-btn px-4 py-2 uppercase">CMS</button>
						<button type="button" data-filter="PAYMENTS" class="filter-btn px-4 py-2 uppercase">PAYMENTS</button>
					</div>
				</div>
				<div
					class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-outline/10 border border-outline/10"
					id="projects-grid-launched"
				>
					{
						launchedProjects.map((p, i) => (
							<a
								href={`/projects/${p.slug}`}
								class="project-card project-card--launched bg-surface group hover:bg-surface-container-high transition-all duration-300 p-8 flex flex-col h-full relative overflow-hidden no-underline text-inherit cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
								data-tags={p.filterTags.join(' ')}
							>
								<div class="absolute top-0 right-0 p-4 opacity-5 font-label text-[40px] font-bold select-none pointer-events-none">{p.number}</div>
								<div class="mb-8 aspect-square w-full bg-surface-container-low overflow-hidden border border-outline/10 relative flex items-center justify-center">
									<div class="absolute inset-0 bg-gradient-to-tr from-primary-container/10 to-transparent z-[1] pointer-events-none" />
									<img
										src={p.schematicImage}
										alt={`${p.title.replace(/_/g, ' ')} — project thumbnail`}
										class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-700"
										width={800}
										height={800}
										sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 28rem"
										loading={i < 6 ? 'eager' : 'lazy'}
										decoding="async"
										fetchpriority={i === 0 ? 'high' : i < 6 ? 'auto' : 'low'}
									/>
									{i === 0 && (
										<div class="absolute bottom-4 left-4 z-[2] flex gap-2 pointer-events-none">
											<span class="w-2 h-2 rounded-full bg-primary-container animate-pulse" />
											<span class="w-2 h-2 rounded-full bg-primary-container/20" />
										</div>
									)}
								</div>
								<h3 class="font-headline text-2xl font-bold mb-2 group-hover:text-secondary transition-colors">{p.title}</h3>
								<p class="text-sm text-outline mb-8 font-body leading-relaxed grow">{p.description}</p>
								<div class="flex flex-wrap gap-2 mb-6">
									<span class="font-label text-[9px] px-2 py-1 bg-surface-container-highest text-secondary border border-primary-container/10">{p.tags[0]}</span>
									<span class="font-label text-[9px] px-2 py-1 bg-surface-container-highest text-secondary border border-primary-container/10">{p.tags[1]}</span>
								</div>
								<div class="pt-4 border-t border-outline/10 flex justify-between items-center">
									<span class="font-label text-[10px] text-outline">STATUS: {p.status}</span>
									<span class="text-secondary flex items-center gap-1 font-label text-[10px] tracking-widest group-hover:translate-x-1 transition-transform">
										VIEW_PROTO <span class="material-symbols-outlined text-xs" aria-hidden="true">arrow_forward</span>
									</span>
								</div>
							</a>
						))
					}
				</div>
			</section>

			{
				internalProjects.length > 0 && (
					<section class="mt-20 pt-16 border-t border-outline/15" aria-labelledby="internal-heading">
						<div class="mb-8 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
							<div class="space-y-2">
								<h2 id="internal-heading" class="font-headline text-3xl md:text-4xl font-bold tracking-tight text-on-surface uppercase">
									Internal <span class="text-secondary">builds</span>
								</h2>
								<p class="max-w-2xl text-outline font-body text-sm leading-relaxed font-label tracking-wide uppercase text-[10px] md:text-xs">
									Private repositories and internal tools — case studies describe architecture and patterns; no public live URL.
								</p>
							</div>
							<div class="flex items-center gap-3 shrink-0" role="group" aria-label="Scroll internal builds">
								<span class="font-label text-[10px] tracking-[0.25em] text-outline uppercase">Carousel</span>
								<div class="flex gap-2">
									<button
										type="button"
										id="internal-builds-prev"
										class="inline-flex items-center justify-center w-10 h-10 border border-outline/25 bg-surface-container-high text-secondary hover:border-secondary/60 hover:bg-surface-container-highest transition-colors duration-200 disabled:opacity-30 disabled:pointer-events-none disabled:cursor-not-allowed focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
										aria-controls="projects-grid-internal"
										aria-label="Scroll internal builds left"
									>
										<span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_left</span>
									</button>
									<button
										type="button"
										id="internal-builds-next"
										class="inline-flex items-center justify-center w-10 h-10 border border-outline/25 bg-surface-container-high text-secondary hover:border-secondary/60 hover:bg-surface-container-highest transition-colors duration-200 disabled:opacity-30 disabled:pointer-events-none disabled:cursor-not-allowed focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
										aria-controls="projects-grid-internal"
										aria-label="Scroll internal builds right"
									>
										<span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_right</span>
									</button>
								</div>
							</div>
						</div>
						<div class="-mx-6 px-6 lg:-mx-8 lg:px-8">
							<div
								class="flex flex-nowrap items-stretch gap-4 overflow-x-auto overflow-y-visible pb-4 pt-1 pe-2 scroll-smooth snap-x snap-mandatory overscroll-x-contain internal-builds-scroll [-webkit-overflow-scrolling:touch]"
								id="projects-grid-internal"
								role="list"
								aria-label="Internal build case studies"
							>
							{internalProjects.map((p) => (
								<a
									role="listitem"
									href={`/projects/${p.slug}`}
									class="project-card project-card--internal bg-surface group hover:bg-surface-container-high transition-all duration-300 p-8 flex flex-col h-[34rem] sm:h-[36rem] relative overflow-hidden ring-1 ring-inset ring-secondary/10 no-underline text-inherit cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary flex-shrink-0 w-[min(100%,22rem)] sm:w-80 snap-start border border-outline/10 border-secondary/20"
								>
									<div class="absolute top-0 right-0 p-4 opacity-5 font-label text-[40px] font-bold select-none pointer-events-none">{p.number}</div>
									<div class="mb-6 aspect-square w-full shrink-0 bg-surface-container-low overflow-hidden border border-secondary/20 relative flex items-center justify-center">
										<div class="absolute inset-0 bg-gradient-to-tr from-secondary/5 to-transparent z-[1] pointer-events-none" />
										<span
											class="material-symbols-outlined relative z-[2] text-6xl text-secondary/50 group-hover:text-secondary transition-all duration-500"
											aria-hidden="true"
										>
											{p.icon}
										</span>
									</div>
									<h3 class="font-headline text-2xl font-bold mb-2 shrink-0 group-hover:text-secondary transition-colors">{p.title}</h3>
									<p class="internal-card-desc text-sm text-outline mb-4 font-body leading-relaxed flex-1 min-h-0 overflow-y-auto pr-1">{p.description}</p>
									<div class="flex flex-wrap gap-2 mb-4 shrink-0">
										<span class="font-label text-[9px] px-2 py-1 bg-surface-container-highest text-secondary border border-secondary/20">{p.tags[0]}</span>
										<span class="font-label text-[9px] px-2 py-1 bg-surface-container-highest text-secondary border border-secondary/20">{p.tags[1]}</span>
									</div>
									<div class="pt-4 border-t border-outline/10 flex justify-between items-center shrink-0">
										<span class="font-label text-[10px] text-secondary">STATUS: {p.status}</span>
										<span class="text-secondary flex items-center gap-1 font-label text-[10px] tracking-widest group-hover:translate-x-1 transition-all">
											VIEW_CASE <span class="material-symbols-outlined text-xs" aria-hidden="true">arrow_forward</span>
										</span>
									</div>
								</a>
							))}
							</div>
						</div>
					</section>
				)
			}
		</div>
	</main>

	<footer class="lg:ml-80 w-full py-8 px-6 flex flex-col md:flex-row justify-between items-center gap-4 bg-surface-container-lowest border-t border-outline/10">
		<div class="font-label text-[10px] tracking-[0.1em] uppercase text-on-surface-variant">
			© {new Date().getFullYear()} THE ZENO TERMINAL. ALL RIGHTS RESERVED.
		</div>
		<div class="flex gap-6 font-label text-[10px] tracking-[0.1em] uppercase flex-wrap justify-center">
			<a class="text-on-surface-variant hover:text-primary transition-opacity cursor-pointer" href="https://github.com/noturzeno" target="_blank" rel="noopener noreferrer">GITHUB</a>
			<a class="text-on-surface-variant hover:text-primary transition-opacity cursor-pointer" href="https://www.linkedin.com/in/zwelinnhtetag/" target="_blank" rel="noopener noreferrer">LINKEDIN</a>
			<a class="text-on-surface-variant hover:text-primary transition-opacity cursor-pointer" href="/about">ABOUT</a>
			<a class="text-on-surface-variant hover:text-primary transition-opacity cursor-pointer" href="/contact">CONTACT</a>
			<div class="flex items-center gap-2 text-secondary font-bold">
				<span class="w-1.5 h-1.5 bg-primary-container rounded-full animate-pulse" />
				SYSTEM_STATUS: OPTIMAL
			</div>
		</div>
	</footer>

	<style>
		.internal-builds-scroll {
			scrollbar-width: thin;
			scrollbar-color: rgb(var(--c-outline) / 0.4) transparent;
		}
		.internal-builds-scroll::-webkit-scrollbar {
			height: 6px;
		}
		.internal-builds-scroll::-webkit-scrollbar-track {
			background: transparent;
		}
		.internal-builds-scroll::-webkit-scrollbar-thumb {
			background-color: rgb(var(--c-outline) / 0.35);
			border-radius: 9999px;
		}
		.internal-card-desc {
			scrollbar-width: thin;
			scrollbar-color: rgb(var(--c-outline) / 0.35) transparent;
		}
		.internal-card-desc::-webkit-scrollbar {
			width: 4px;
		}
		.internal-card-desc::-webkit-scrollbar-thumb {
			background-color: rgb(var(--c-outline) / 0.3);
			border-radius: 9999px;
		}
	</style>

	<script is:inline>
		(function () {
			var buttons = document.querySelectorAll('#project-filters .filter-btn');
			var cards = document.querySelectorAll('#projects-grid-launched .project-card--launched');
			function setActive(btn) {
				buttons.forEach(function (b) {
					b.classList.remove('filter-btn--active');
				});
				btn.classList.add('filter-btn--active');
			}
			buttons.forEach(function (btn) {
				btn.addEventListener('click', function () {
					var f = btn.getAttribute('data-filter') || 'all';
					setActive(btn);
					cards.forEach(function (card) {
						var tags = (card.getAttribute('data-tags') || '').split(/\s+/).filter(Boolean);
						var show = f === 'all' || tags.indexOf(f) !== -1;
						card.style.display = show ? '' : 'none';
					});
				});
			});
		})();
		(function () {
			var strip = document.getElementById('projects-grid-internal');
			var prevBtn = document.getElementById('internal-builds-prev');
			var nextBtn = document.getElementById('internal-builds-next');
			if (!strip || !prevBtn || !nextBtn) return;
			function stepDistance() {
				var card = strip.querySelector('.project-card--internal');
				if (!card) return Math.max(280, strip.clientWidth * 0.75);
				var style = window.getComputedStyle(strip);
				var gap = parseFloat(style.columnGap || style.gap) || 16;
				return card.getBoundingClientRect().width + gap;
			}
			function syncNav() {
				var maxScroll = strip.scrollWidth - strip.clientWidth;
				var left = strip.scrollLeft;
				var atStart = left <= 2;
				var atEnd = maxScroll <= 2 || left >= maxScroll - 2;
				prevBtn.disabled = atStart;
				nextBtn.disabled = atEnd;
			}
			prevBtn.addEventListener('click', function () {
				strip.scrollBy({ left: -stepDistance(), behavior: 'smooth' });
			});
			nextBtn.addEventListener('click', function () {
				strip.scrollBy({ left: stepDistance(), behavior: 'smooth' });
			});
			strip.addEventListener('scroll', syncNav, { passive: true });
			window.addEventListener('resize', syncNav);
			function runSync() {
				window.requestAnimationFrame(syncNav);
			}
			runSync();
			window.addEventListener('load', runSync);
		})();
	</script>
</Layout>
