---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { getExperienceYears } from '../data/experience';

const yearsExp = getExperienceYears();
---

<Layout title="ABOUT // ZENO_TERMINAL">
	<!-- TopAppBar -->
	<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface-container-lowest border-b border-outline/15 zeno-header-shadow">
		<a href="/" class="flex items-center gap-3">
			<span class="material-symbols-outlined text-secondary">terminal</span>
			<span class="font-headline font-black text-secondary tracking-[-0.04em] text-xl uppercase">ZENO_TERMINAL</span>
		</a>
		<div class="hidden md:flex items-center gap-6">
			<nav class="flex gap-8 items-center">
				<a class="font-label text-xs tracking-widest text-on-surface-variant hover:text-primary transition-all" href="/">HOME</a>
				<a class="font-label text-xs tracking-widest text-on-surface-variant hover:text-primary transition-all" href="/projects">PROJECTS</a>
				<a class="font-label text-xs tracking-widest text-primary font-semibold underline underline-offset-8 transition-all" href="/about">ABOUT</a>
				<a class="font-label text-xs tracking-widest text-on-surface-variant hover:text-primary transition-all" href="/contact">CONTACT</a>
			</nav>
			<ThemeToggle />
		</div>
		<div class="md:hidden flex items-center gap-2">
			<ThemeToggle />
			<button
				type="button"
				class="text-secondary p-2 hover:bg-surface-container-high transition-all bg-transparent border-0 cursor-pointer"
				aria-label="Open menu"
				aria-controls="mobile-menu-about"
				aria-expanded="false"
				data-mobile-menu-toggle
			>
				<span class="material-symbols-outlined" aria-hidden="true">menu</span>
			</button>
		</div>
		<nav
			id="mobile-menu-about"
			class="md:hidden hidden absolute top-16 left-0 right-0 bg-surface-container-lowest border-b border-outline/15 px-6 py-4"
			data-mobile-menu
		>
			<div class="flex flex-col gap-3 font-label text-xs tracking-widest uppercase">
				<a class="text-on-surface-variant hover:text-primary" href="/">Home</a>
				<a class="text-on-surface-variant hover:text-primary" href="/projects">Projects</a>
				<a class="text-primary font-semibold" href="/about">About</a>
				<a class="text-on-surface-variant hover:text-primary" href="/contact">Contact</a>
			</div>
		</nav>
	</header>

	<main class="pt-16 min-h-screen">
		<!-- Hero Section: Narrative & Portrait -->
		<section class="relative px-6 md:px-12 py-20 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
			<div class="lg:col-span-7 space-y-8">
				<div class="inline-block px-3 py-1 bg-surface-container-high border-l-2 border-primary-container">
					<p class="font-label text-[10px] tracking-[0.2em] text-primary-fixed-dim uppercase">SYSTEM_MANIFESTO_V4.0</p>
				</div>
				<h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter text-on-surface leading-[0.9] uppercase">
					Full-Stack <span class="text-secondary">Laravel</span> &amp; <span class="text-outline">Enterprise Delivery.</span>
				</h1>
				<div class="max-w-xl">
					<p class="text-on-surface-variant text-lg leading-relaxed font-light">
						<span class="text-primary font-medium">Zwel Linn Htet Ag</span> — software engineer with <span class="text-primary font-medium">{yearsExp}+ years</span> building scalable enterprise applications. I lead cross-functional teams across <span class="text-primary font-medium">FinTech</span>, <span class="text-primary font-medium">e-commerce</span>, and portals — from analysis and architecture through code review, mentorship, and production deployment. At <span class="text-primary font-medium">ITVision Hub</span> I ran high-intensity <span class="text-on-surface font-medium">technical instruction</span> for developer cohorts in parallel with senior delivery. I also take on <span class="text-primary font-medium">freelance</span> and contract work for teams that need senior Laravel and full-stack execution on a defined timeline.
					</p>
				</div>
				<div class="flex gap-6 pt-4 flex-wrap">
					<a href="/documents/Zeno-Resume.pdf" download="Zeno-Resume.pdf" class="bg-primary-container text-on-primary px-8 py-4 font-label text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all active:scale-95 flex items-center gap-2">
						Download_CV <span class="material-symbols-outlined text-sm">download</span>
					</a>
					<a href="https://www.linkedin.com/in/zwelinnhtetag/" target="_blank" rel="noopener noreferrer" class="border border-outline/20 text-primary px-8 py-4 font-label text-xs font-bold uppercase tracking-widest hover:bg-black/[0.04] transition-all flex items-center gap-2">
						LinkedIn <span class="material-symbols-outlined text-sm">arrow_outward</span>
					</a>
				</div>
			</div>
			<div class="lg:col-span-5 relative group">
				<div class="absolute -inset-4 bg-primary-container/5 blur-3xl rounded-full group-hover:bg-primary-container/10 transition-all duration-700"></div>
				<div class="relative aspect-[4/5] bg-surface-container-high overflow-hidden border border-outline/10">
					<img
						alt="Zwel Linn Htet Ag"
						class="w-full h-full object-cover"
						src="/images/zeno.jpg"
						width="1024"
						height="1024"
						loading="lazy"
						decoding="async"
					/>
					<div class="absolute bottom-0 left-0 p-6 w-full bg-gradient-to-t from-surface-dim to-transparent">
						<p class="font-label text-[10px] text-secondary tracking-widest uppercase">ID_NUM: 0092-ALPHA</p>
						<p class="font-headline text-2xl font-bold uppercase tracking-tighter">Full-Stack Engineer</p>
						<p class="font-label text-[10px] text-on-surface-variant/90 tracking-widest uppercase mt-1">Freelance · Contract</p>
					</div>
				</div>
				<div class="absolute -bottom-6 -right-6 md:-right-12 bg-surface-container-highest p-6 border border-outline/15 hidden md:block">
					<div class="font-label text-[10px] text-outline mb-2 uppercase">Core_Stats</div>
					<div class="space-y-3">
						<div class="flex justify-between gap-8 items-center">
							<span class="text-[10px] uppercase text-on-surface-variant">Uptime</span>
							<span class="text-[10px] text-primary font-bold">99.9%</span>
						</div>
						<div class="flex justify-between gap-8 items-center">
							<span class="text-[10px] uppercase text-on-surface-variant">Latency</span>
							<span class="text-[10px] text-primary font-bold">12ms</span>
						</div>
						<div class="flex justify-between gap-8 items-center">
							<span class="text-[10px] uppercase text-on-surface-variant">Location</span>
							<span class="text-[10px] text-primary font-bold">Bangkok, TH</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- TECHNICAL_MATRIX Section -->
		<section class="bg-surface-container-low py-24 technical-grid border-y border-outline/10">
			<div class="max-w-7xl mx-auto px-6 md:px-12">
				<div class="flex flex-col md:flex-row justify-between items-baseline mb-16 gap-4">
					<h2 class="font-headline text-4xl font-black tracking-tighter uppercase text-on-surface">TECHNICAL_MATRIX</h2>
					<div class="h-px bg-outline/20 grow mx-8 hidden md:block"></div>
					<span class="font-label text-xs text-secondary tracking-[0.3em]">SKILLS_SYSTEM_LOADED</span>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-outline/15 border border-outline/15">
					<!-- FRONTEND ARCHITECTURE -->
					<div class="bg-surface-dim p-8 hover:bg-surface-container-high transition-colors group">
						<div class="w-10 h-10 mb-6 flex items-center justify-center bg-primary-container/10 group-hover:bg-primary-container transition-colors">
							<span class="material-symbols-outlined text-secondary group-hover:text-on-primary transition-colors">layers</span>
						</div>
						<h3 class="font-label text-xs font-bold text-secondary mb-4 tracking-widest">FRONTEND ARCHITECTURE</h3>
						<ul class="space-y-3">
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> React / Next.js
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> TypeScript Core
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Tailwind CSS
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Framer Motion
							</li>
						</ul>
					</div>
					<!-- BACKEND -->
					<div class="bg-surface-dim p-8 hover:bg-surface-container-high transition-colors group">
						<div class="w-10 h-10 mb-6 flex items-center justify-center bg-primary-container/10 group-hover:bg-primary-container transition-colors">
							<span class="material-symbols-outlined text-secondary group-hover:text-on-primary transition-colors">database</span>
						</div>
						<h3 class="font-label text-xs font-bold text-secondary mb-4 tracking-widest">BACKEND</h3>
						<ul class="space-y-3">
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Laravel / PHP
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Yii / Node.js
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> REST APIs &amp; integrations
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> MySQL / relational data
							</li>
						</ul>
					</div>
					<!-- CLOUD_OPS -->
					<div class="bg-surface-dim p-8 hover:bg-surface-container-high transition-colors group">
						<div class="w-10 h-10 mb-6 flex items-center justify-center bg-primary-container/10 group-hover:bg-primary-container transition-colors">
							<span class="material-symbols-outlined text-secondary group-hover:text-on-primary transition-colors">cloud</span>
						</div>
						<h3 class="font-label text-xs font-bold text-secondary mb-4 tracking-widest">CLOUD_OPS</h3>
						<ul class="space-y-3">
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Server deployment &amp; hosting
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Environment &amp; release discipline
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Performance &amp; reliability focus
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Git / collaboration workflows
							</li>
						</ul>
					</div>
					<!-- DESIGN_ENGINEERING -->
					<div class="bg-surface-dim p-8 hover:bg-surface-container-high transition-colors group">
						<div class="w-10 h-10 mb-6 flex items-center justify-center bg-primary-container/10 group-hover:bg-primary-container transition-colors">
							<span class="material-symbols-outlined text-secondary group-hover:text-on-primary transition-colors">architecture</span>
						</div>
						<h3 class="font-label text-xs font-bold text-secondary mb-4 tracking-widest">DESIGN &amp; DELIVERY</h3>
						<ul class="space-y-3">
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Figma / UI systems
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> UX, wireframing, prototyping
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Project analysis &amp; specs
							</li>
							<li class="flex items-center gap-2 text-on-surface-variant font-label text-[11px] uppercase tracking-wider">
								<span class="w-1 h-1 bg-outline rounded-full"></span> Scrum / Agile · Jira · Trello
							</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Education -->
		<section class="py-16 max-w-7xl mx-auto px-6 md:px-12 border-t border-outline/10">
			<p class="font-label text-[10px] text-outline tracking-[0.5em] mb-4">CREDENTIALS</p>
			<h2 class="font-headline text-3xl md:text-4xl font-black tracking-tighter uppercase text-on-surface mb-4">Education</h2>
			<p class="text-on-surface-variant leading-relaxed max-w-3xl">
				<span class="font-label text-xs text-secondary uppercase tracking-widest">Bachelor of Computer Science</span>
				— University of Computer Studies (2013–2018). Built a rigorous base in algorithms, systems, and software engineering, then went deep on <span class="text-on-surface font-medium">Artificial Intelligence</span> and <span class="text-on-surface font-medium">Web Engineering</span> — completing the specialization with <span class="text-primary font-medium">A+</span> credit. That mix still shapes how I design APIs, model data, and ship interfaces that have to scale and stay maintainable.
			</p>
			<p class="text-on-surface-variant/80 text-sm mt-4 font-label uppercase tracking-wider">Languages: Burmese (native) · English (professional working — async &amp; cross-border teams)</p>
		</section>

		<!-- EXPERIENCE_LOG Timeline -->
		<section class="py-24 max-w-7xl mx-auto px-6 md:px-12">
			<div class="mb-20">
				<p class="font-label text-[10px] text-outline tracking-[0.5em] mb-4">CHRONOLOGICAL_FLOW</p>
				<h2 class="font-headline text-5xl font-black tracking-tighter uppercase">EXPERIENCE_LOG</h2>
			</div>
			<div class="space-y-12">
				<div class="grid grid-cols-1 md:grid-cols-12 gap-6 group">
					<div class="md:col-span-3 flex flex-col justify-start">
						<span class="font-label text-secondary text-xs font-bold tracking-widest">2021 — PRESENT</span>
						<span class="font-label text-outline text-[10px] uppercase mt-1 tracking-tighter">REMOTE</span>
					</div>
					<div class="md:col-span-9 border-l border-outline/15 pl-8 pb-12 relative">
						<div class="absolute -left-1 top-0 w-2 h-2 bg-primary-container"></div>
						<h3 class="font-headline text-2xl font-bold uppercase text-on-surface mb-2">Senior Developer</h3>
						<p class="font-label text-xs text-secondary-fixed mb-6 tracking-widest uppercase">Visible One</p>
						<p class="text-on-surface-variant leading-relaxed max-w-3xl mb-6">
							Own the full delivery loop for distributed commerce, portals, payment products, and CMS platforms — from project analysis and scoping through backlog shaping, task breakdown and assignment, architecture, code review, and production deploys (including editor workflows, structured content, and safe publish paths). Project maintenance and enhancement sit on the same critical path: production stability, regression fixes, dependency and security hygiene, refactors where they reduce risk, and scoped upgrades that keep products current after go-live. I operate as the engineering-side project owner: team alignment, day-to-day project management, stakeholder communication, and predictable releases — with code quality, security, and operability as non-negotiables on every ship.
						</p>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Laravel</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">E-Commerce</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Payments</span>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-12 gap-6 group">
					<div class="md:col-span-3 flex flex-col justify-start">
						<span class="font-label text-on-surface-variant text-xs font-bold tracking-widest">2019 — 2021</span>
						<span class="font-label text-outline text-[10px] uppercase mt-1 tracking-tighter">YANGON</span>
					</div>
					<div class="md:col-span-9 border-l border-outline/15 pl-8 pb-12 relative">
						<div class="absolute -left-1 top-0 w-2 h-2 bg-primary-container ring-4 ring-primary-container/20"></div>
						<h3 class="font-headline text-2xl font-bold uppercase text-on-surface mb-2">Senior Developer · Technical Instructor</h3>
						<p class="font-label text-xs text-secondary-fixed mb-6 tracking-widest uppercase">ITVision Hub</p>
						<p class="text-on-surface-variant leading-relaxed max-w-3xl mb-6">
							Led a team of 10–15 developers through full-stack enterprise delivery — e-commerce, job portals, and bespoke IT solutions — owning technical design, integrations, and hardened deployments across <span class="text-on-surface font-medium">payment systems</span> and <span class="text-on-surface font-medium">POS</span> footprints. Set the bar for how we broke down epics, reviewed code, and shipped without leaving ops or finance in the dark.
						</p>
						<div class="max-w-3xl mb-6 pl-5 border-l-2 border-secondary/50 bg-surface-container-low/80 py-5 pr-5 md:pr-8">
							<p class="font-label text-[10px] text-secondary tracking-[0.35em] uppercase mb-3">Instruction_vector // high bandwidth</p>
							<p class="text-on-surface-variant leading-relaxed">
								Ran ITVision Hub’s <span class="text-on-surface font-medium">technical instruction</span> track in parallel: cohort-style programs and intensive workshops where engineers did not passively consume slides — they <span class="text-primary font-medium">built, broke, and fixed</span> under the same constraints as production. I designed lesson arcs around Laravel architecture, API contracts, integration discipline, and release hygiene; stood shoulder-to-shoulder for live debugging and review-style critique until “I followed the tutorial” turned into <span class="text-on-surface font-medium">I can own this module, defend it in review, and land it safely</span>. That dual mandate — <span class="text-on-surface font-medium">lead delivery and lift the floor on craft</span> — is where I learned to explain complex systems with clarity and to scale judgment, not just headcount.
							</p>
						</div>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Team lead</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Instruction</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Curriculum</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Mentorship</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">FinTech</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">POS</span>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-12 gap-6 group">
					<div class="md:col-span-3 flex flex-col justify-start">
						<span class="font-label text-on-surface-variant text-xs font-bold tracking-widest">MAY — JUL 2019</span>
						<span class="font-label text-outline text-[10px] uppercase mt-1 tracking-tighter">REMOTE</span>
					</div>
					<div class="md:col-span-9 border-l border-outline/15 pl-8 pb-12 relative">
						<div class="absolute -left-1 top-0 w-2 h-2 bg-outline"></div>
						<h3 class="font-headline text-2xl font-bold uppercase text-on-surface mb-2">UI/UX Developer</h3>
						<p class="font-label text-xs text-secondary-fixed mb-6 tracking-widest uppercase">Wunderfauks</p>
						<p class="text-on-surface-variant leading-relaxed max-w-3xl mb-6">
							Ran UI/UX end to end: rapid prototyping, high-fidelity interfaces, and handoff-ready specs. Lean cycles: validate early, cut noise, and ship experiences that feel fast and intentional rather than decorative.
						</p>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Figma</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Prototyping</span>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-12 gap-6 group">
					<div class="md:col-span-3 flex flex-col justify-start">
						<span class="font-label text-on-surface-variant text-xs font-bold tracking-widest">2018 — 2019</span>
						<span class="font-label text-outline text-[10px] uppercase mt-1 tracking-tighter">YANGON</span>
					</div>
					<div class="md:col-span-9 border-l border-outline/15 pl-8 pb-12 relative">
						<div class="absolute -left-1 top-0 w-2 h-2 bg-outline"></div>
						<h3 class="font-headline text-2xl font-bold uppercase text-on-surface mb-2">Developer</h3>
						<p class="font-label text-xs text-secondary-fixed mb-6 tracking-widest uppercase">Property Star · SGCondo</p>
						<p class="text-on-surface-variant leading-relaxed max-w-3xl mb-6">
							Built and maintained secure, scalable internal real estate websites; collaborated with stakeholders on functional, user-friendly interfaces.
						</p>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Real estate</span>
							<span class="px-3 py-1 bg-surface-container-high border border-outline/10 font-label text-[9px] text-outline uppercase">Full-stack</span>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-12 gap-6 group">
					<div class="md:col-span-3 flex flex-col justify-start">
						<span class="font-label text-on-surface-variant text-xs font-bold tracking-widest">2017 — 2018</span>
						<span class="font-label text-outline text-[10px] uppercase mt-1 tracking-tighter">REMOTE · SG</span>
					</div>
					<div class="md:col-span-9 border-l border-outline/15 pl-8 relative">
						<div class="absolute -left-1 top-0 w-2 h-2 bg-outline"></div>
						<h3 class="font-headline text-2xl font-bold uppercase text-on-surface mb-2">Junior Developer · Internship</h3>
