---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
---

<button
	type="button"
	data-theme-toggle
	class:list={[
		'flex h-9 w-9 shrink-0 items-center justify-center rounded border border-outline/25 text-on-surface-variant transition-colors hover:bg-surface-container-high hover:text-on-surface',
		className,
	]}
	aria-label="Switch to light mode"
>
	<span class="material-symbols-outlined text-xl" aria-hidden="true" data-theme-toggle-icon>light_mode</span>
</button>
